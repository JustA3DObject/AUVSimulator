        </sensor>

        <sensor name="pressure" type="pressure" rate="5.0">
            <ros_publisher topic="/girona500/pressure"/>
            <link name="Vehicle"/>
            <origin rpy="0.0 0.0 0.0" xyz="-0.48 0.35 -0.4"/>
            <noise pressure="5.0"/>
        </sensor>

        <sensor name="dvl" type="dvl" rate="20.0">
            <ros_publisher topic="/girona500/dvl" altitude_topic="/girona500/dvl/altitude"/>
