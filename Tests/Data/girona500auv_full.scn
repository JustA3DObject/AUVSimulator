    <robot name="girona500" fixed="false" self_collisions="false">
        <base_link name="Vehicle" type="compound" physics="submerged">

        <dynamic>
            <hydrodynamics viscous_drag="20.0 20.0 20.0" quadratic_drag="100.0 100.0 100.0"/>
