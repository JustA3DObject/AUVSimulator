            <autoping rate="1.0"/>
            <noise range="0.05" horizontal_angle="0.2" vertical_angle="0.5"/>
            <resolution range="0.1" angle="0.1"/>
            <origin xyz="0.0 0.5 0.0" rpy="0.0 0.0 0.0"/>
            <link name="FunnelLink"/>
        </comm>
        
        <world_transform rpy="0.0 0.0 0" xyz="0.0 0.0 10.0"/>
