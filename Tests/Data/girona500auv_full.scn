<?xml version="1.0"?>
<scenario>
    <environment>
        <ned latitude="41.7777" longitude="3.0333"/>
        
        <ocean>
            <water density="1025.0" jerlov="0.2"/>
            <waves height="0.02" length="10.0" period="2.0"/>
            <particles enabled="true" />
            
            <current type="uniform">
                <velocity xyz="0.5 0.0 0.0"/>
            </current>
        </ocean>

        <atmosphere>
            <sun azimuth="20.0" elevation="50.0"/>
            <conditions temperature="20.0" pressure="101300.0" humidity="0.5"/>
            
            <wind type="uniform">
                <velocity xyz="5.0 0.0 0.0"/>
            </wind>
        </atmosphere>
    </environment>

    <materials>
        <material name="Fiberglass" density="1800.0" restitution="0.5" friction="0.8"/>
        <material name="Aluminium" density="2700.0" restitution="0.7" friction="0.5"/>
        <material name="Neutral" density="1000.0" restitution="0.5" friction="0.5"/>
        <material name="Magnet" density="7500.0" restitution="0.5" friction="0.8" magnetic="5.0"/>
        <material name="NeutralSteel" density="1025.0" restitution="0.5" friction="0.8" magnetic="-5.0"/>
    </materials>

    <looks>
        <look name="yellow" gray="0.0" rgb="1.0 0.9 0.0" roughness="0.2"/>
        <look name="gray" gray="0.5" roughness="0.4"/>
        <look name="duct" gray="0.1" roughness="0.5"/>
        <look name="manipulator" rgb="0.2 0.2 0.2" roughness="0.6"/>
        <look name="propeller" rgb="0.8 0.6 0.2" roughness="0.3"/>
        <look name="red" rgb="1.0 0.0 0.0" roughness="0.2"/>
        <look name="white_led" rgb="5.0 5.0 5.0" roughness="0.0"/>
    </looks>

    <robot name="dock" fixed="true" self_collisions="false">
        <base_link name="FunnelLink" type="compound" physics="submerged">

            <external_part name="Latch_Magnet" type="cylinder" physics="submerged" buoyant="false">
