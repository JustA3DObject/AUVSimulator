            <link name="Vehicle"/>
            <origin rpy="3.1416 0.0 -0.785" xyz="-0.75 0.0 0.4"/>
            <specs beam_angle="30.0"/>
            <range velocity="9.0 9.0 9.0" altitude_min="0.5" altitude_max="81.0"/>
            <water_layer minimum_layer_size="5.0" boundary_near="10.0" boundary_far="30.0"/>
            <noise velocity="0.0015" altitude="0.001"/>
        </sensor>

        <sensor name="acc" type="accelerometer" rate="100.0">
            <ros_publisher topic="/girona500/accelerometer"/>
            <history samples="1000"/>
            <link name="Vehicle"/>
            <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
        </sensor>

        <sensor name="proscilica" type="camera" rate="10.0">
            <ros_publisher topic="/girona500/camera/image_raw"/>
            <link name="Vehicle"/>
            <origin rpy="0.0 0.0 1.571" xyz="0.5 -0.12 0.5"/>
            <specs resolution_x="1360" resolution_y="1024" horizontal_fov="55.0"/>
        </sensor>

        <sensor name="front_camera" type="camera" rate="10.0">
            <ros_publisher topic="/girona500/front_camera/image_raw"/>
            <link name="Vehicle"/>
            <origin rpy="1.571 0.0 1.571" xyz="1.2 0.0 0.0"/>
            <specs resolution_x="1360" resolution_y="1024" horizontal_fov="80.0"/>
        </sensor>

        <sensor name="fls" type="fls" rate="10.0">
            <ros_publisher topic="/girona500/fls/image_raw"/>
            <link name="Vehicle"/>
            <origin xyz="0.8 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <specs beams="128" bins="512" horizontal_fov="120.0" vertical_fov="20.0" output_format="uint8"/>
            <settings range_min="0.5" range_max="30.0" gain="1.1"/>
            <noise multiplicative="0.01" additive="0.02"/>
            <display colormap="hot"/>
        </sensor>

        <comm name="Vehicle_Beacon" device_id="2" type="acoustic_modem">
            <specs min_vertical_fov="0.0" max_vertical_fov="360.0" range="1000.0"/>
            <connect device_id="1" occlusion_test="false"/>
            <origin xyz="0.0 0.0 0.5" rpy="0.0 0.0 0.0"/>
            <link name="Vehicle"/>
            <ros_publisher topic="/girona500/modem"/>
        </comm>

