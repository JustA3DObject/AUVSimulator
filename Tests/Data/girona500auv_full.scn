                <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
                <material name="Magnet"/>
                <look name="gray"/>
                <compound_transform rpy="1.571 0.0 0.0" xyz="0.0 1.0 0.0"/>
            </external_part>
            
            <external_part name="FunnelMesh_Visual" type="model" physics="submerged" buoyant="false">
